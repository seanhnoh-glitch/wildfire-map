# Copy to `.env` (Expo auto-loads it). Only needed for a PHYSICAL phone, where the
# app must reach your PC by its LAN IP instead of the emulator alias.
#
# Find your PC's IPv4 with `ipconfig` (Wi-Fi adapter), then:
# EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
#
# Emulator users can leave this unset — the app defaults to http://10.0.2.2:8000.
EXPO_PUBLIC_API_URL=
