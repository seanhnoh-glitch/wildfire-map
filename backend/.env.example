# Copy this file to `.env` and fill in what you have. Everything works without
# keys EXCEPT NASA FIRMS active-fire detections, which need a free MAP_KEY.

# --- NASA FIRMS (active fire / hotspot detections) ---------------------------
# Get a free key instantly: https://firms.modaps.eosdis.nasa.gov/api/area/
# Without it, the app still works using NIFC WFIGS incidents (no key needed);
# it just won't show satellite hotspot pixels.
FIRMS_MAP_KEY=

# --- Server ------------------------------------------------------------------
# Comma-separated origins allowed to call the API (Expo dev URL, phone LAN IP,
# deployed frontend). "*" is fine for local dev.
CORS_ORIGINS=*
HOST=0.0.0.0
PORT=8000

# --- Prediction engine -------------------------------------------------------
# "auto"     -> use ForeFire if available, else the built-in elliptical model
# "forefire" -> require ForeFire (error if not installed)
# "builtin"  -> always use the built-in elliptical spread model
PREDICTION_ENGINE=auto

# Path to the compiled ForeFire binary (only used if PREDICTION_ENGINE != builtin).
# See docs/FOREFIRE_SETUP.md. Leave blank to use Python bindings or the fallback.
FOREFIRE_BINARY=

# --- Optional data-layer keys (the built-in model works without these) -------
# LANDFIRE and USGS 3DEP are public ArcGIS services and need no key.
# A geocoder key is only needed if you swap the free US Census geocoder for
# Mapbox/Google to get better autocomplete.
MAPBOX_TOKEN=
