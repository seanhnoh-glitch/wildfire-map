# Copy this file to `.env` and fill in what you have. Everything works without
# keys EXCEPT NASA FIRMS active-fire detections, which need a free MAP_KEY.

# --- NASA FIRMS (active fire / hotspot detections) ---------------------------
# Get a free key instantly: https://firms.modaps.eosdis.nasa.gov/api/area/
# Without it, the app still works using NIFC WFIGS incidents (no key needed);
# it just won't show satellite hotspot pixels.
FIRMS_MAP_KEY=

# --- Server ------------------------------------------------------------------
# Comma-separated origins allowed to call the API (Expo dev URL, phone LAN IP,
# deployed frontend). "*" is fine for local dev.
CORS_ORIGINS=*
HOST=0.0.0.0
PORT=8000

# --- Prediction engine (ForeFire only) ---------------------------------------
# The /predict endpoint runs the ForeFire front-tracking simulator via the
# pyforefire bindings (compiled into the Docker image). There is no fallback:
# if pyforefire is missing, /predict returns HTTP 503. See docs/FOREFIRE_SETUP.md.
#
# Propagation model. "Farsite" pairs with the built-in STDfarsiteFuelsTable
# (keyed by LANDFIRE FBFM40 codes). Other options: "Rothermel", "WindDriven".
FOREFIRE_PROPAGATION_MODEL=Farsite

# Path to a standalone compiled ForeFire binary (optional; the bindings are used
# for the simulation itself). See docs/FOREFIRE_SETUP.md.
FOREFIRE_BINARY=

# --- Mapbox (evacuation routing + optional geocoder) -------------------------
# Enables traffic-aware evacuation routes (Directions `driving-traffic`). Get a
# free token at https://account.mapbox.com/access-tokens/ (free tier ~100k
# requests/mo). Without it, /evacuation still returns safe destinations but no
# drive routes. Shelter data (FEMA/OpenStreetMap) needs no key.
MAPBOX_TOKEN=
